# ---------------------------------------------------------------------------
# PRIVATE DATA — MUST NEVER ENTER GIT HISTORY
# Ref: TECHNICAL_ADDENDUM.md §21 (Private-data exclusion)
# The repository is PUBLIC. Git history is permanent. Do not weaken this list.
# ---------------------------------------------------------------------------

# Audio (WhatsApp voice notes and any other media)
*.opus
*.ogg
*.mp3
*.wav
*.m4a
*.aac
*.flac
*.webm
*.mp4

# Databases
*.sqlite
*.sqlite3
*.sqlite3-wal
*.sqlite3-shm
*.db

# Backup / migration packages
*.dntbackup

# Runtime data folders
Output/
Logs/
Backups/
Models/
Temp/
real-fixtures/
"Different Network Transcribe Data"/

# ---------------------------------------------------------------------------
# EXCEPTIONS: synthetic fixtures generated by tests are allowed
# (they contain no real names, no real audio, no real phone numbers)
# ---------------------------------------------------------------------------
!tests/fixtures/synthetic/**
!tests/fixtures/synthetic/**/*.wav
!tests/fixtures/synthetic/**/*.opus

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.test-tmp/
.test-tmp-*/
.test-temp-*/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
dist/
build/

# ---------------------------------------------------------------------------
# Packaging output (built assets are release artifacts, never committed)
# Ref: PROJECT_BLUEPRINT.md §17.1
# ---------------------------------------------------------------------------
release/
packaging/pyinstaller/build/
packaging/pyinstaller/dist/
*.exe
*.zip
!scripts/**/*.ps1

# ---------------------------------------------------------------------------
# Editor / OS
# ---------------------------------------------------------------------------
.vscode/
.idea/
Thumbs.db
desktop.ini
